# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=sigedash
POSTGRES_USER=sigedash
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_AQUI

# ── Backend ASP.NET Core ───────────────────────────────────────────────────────
# Deve coincidir com POSTGRES_* acima
ConnectionStrings__Postgres=Host=db;Port=5432;Database=sigedash;Username=sigedash;Password=TROCAR_SENHA_FORTE_AQUI

# JWT — gerar com: openssl rand -base64 48
Jwt__SecretKey=GERAR_CHAVE_ALEATORIA_MINIMO_32_CARACTERES_AQUI
Jwt__Issuer=sigedash
Jwt__Audience=sigedash-pwa

# CORS — domínio(s) externos que acessam a API (se PWA no mesmo origin, pode deixar só o domínio)
AllowedOrigins__0=https://dash.sigedash.com.br

# Imagem Docker usada pelo docker-compose (CI/CD seta automaticamente via tag)
# Deixe em branco em dev (faz build local). Em produção: ghcr.io/sistemasbr/sigedash:vX.Y.Z
BACKEND_IMAGE=ghcr.io/sistemasbr/sigedash:latest
